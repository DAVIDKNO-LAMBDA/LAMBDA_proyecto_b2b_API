    {
      "name": "🔑 1. AUTENTICACIÓN Y SETUP",
      "item": [
        {
          "name": "1.1 Login Admin Lambda",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has access token', () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response).to.have.property('access');",
                  "    pm.collectionVariables.set('admin_token', response.access);",
                  "});",
                  "",
                  "pm.test('User is Admin Lambda', () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.user.email).to.equal('admin@lambdacommerce.com');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@lambdacommerce.com\",\n  \"password\": \"Lambda123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/usuarios/login/",
              "host": ["{{base_url}}"],
              "path": ["api", "usuarios", "login", ""]
